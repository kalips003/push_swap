NAMEE = push_swap

# 	DOWNLOAD AND PUT THE TESTER AT THE ROOT OF YOUR PROJECT
# 		if the tester isnt 'checker_linux', change the name below
CHECKER_NAME = checker_linux

# ------------------------------------------------------------------------------------------------------------- >
# 	AVAILABLE: (see desccription below)
# 	make a - test once with random numbers
# 	make m - test many times with random numbers
# 	make n - test bad args

MIN = -999
MAX = 999
HOW_MANY = 100
HOW_MANY_TIMES = 25

#######################################################################################
# MAKE A: Run PUSH_SWAP with 'HOW_MANY' random numbers between 'MIN' and 'MAX'
# 
a: $(NAMEE)
	@$(call random_shmol_cat, "\'tis push shwap", $(HOW_MANY) number ね?, $(CLS), );
	@ARGS=$$(seq $(MIN) $(MAX) | shuf -n $(HOW_MANY) | tr '\n' ' ' | sed -r 's/ $$//'); \
	echo $$ARGS; \
	./$(word 1, $^) $$ARGS


#######################################################################################
# MAKE M: Run PUSH_SWAP $HOW_MANY_TIMES times, output the total move cost
# 
m: libft $(NAME) inc/push_swap.h
	@$(call shmol_cat_color, $(C_123), $(C_321), "\'tis push shwap tesshter", "$(HOW_MANY) numbers、$(HOW_MANY_TIMES) times ね?", $(CLS), );
	@total=0; \
	for i in $$(seq 1 $(HOW_MANY_TIMES)); do \
		ARGS=$$(seq $(MIN) $(MAX) | shuf -n $(HOW_MANY) | tr '\n' ' ' | sed -r 's/ $$//'); \
		output=$$(./$(NAME) $$ARGS); \
		count=$$(echo "$$output" | wc -l); \
		result=$$(echo "$$output" | ./$(CHECKER_NAME) $$ARGS); \
		echo -e -n "$(C_123)" "test $$i: " "$(C_321)" "$$count" "$(C_123)" "moves: "; \
		if [ "$$result" = "KO" ]; then \
			echo -e "$(NOK)"; \
			echo -e "$(C_411)" "FAILED args saved in bad_args, output saved in bad_output"; \
			echo "$$ARGS" > bad_args; \
			echo "$$output" > bad_output; \
		else \
			echo -e "$(OK)"; \
		fi; \
		((total += count)); \
	done; \
	average=$$((total / $(HOW_MANY_TIMES))); \
	$(call random_shmol_cat, "heres average numbar:", $$average, , )


BAD_ARGS =  "0 1 2 2a 5" "0 1 2 wtf" "0 1 2 -2147483648 -2147483650" "0 1 2 9999999999 9" "4" "" " "  "-" "i want ..." "0 1-2 8 5" "0 1 2 8 1 5"
#######################################################################################
# MAKE N: Run a dozen bad arguments, with valgrind
# 
n: $(NAMEE)
	@for arg in $(BAD_ARGS); do \
	$(call random_shmol_cat, teshting lots of bad args:, $$arg, $(CLS), ); \
	$(VALGRIIND) ./$(word 1, $^) $$arg; \
	echo -e "\t$(BLINK)$(C_430)~ Press Enter to continue...$(RESET)"; \
	read -p "" key; \
	done
	$(call random_shmol_cat, this one should work fine:, 1 5 2 7 -3, $(CLS), )
	$(VALGRIIND) ./$(word 1, $^) 1 5 2 7


